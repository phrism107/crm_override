{
  "name": "crm-override-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "node ./custom-build.js",
    "dev": "vite",
    "build": "yarn prebuild && vite build --base=/assets/crm_override/frontend/ && yarn copy-html-entry",
    "copy-html-entry": "cp ../crm_override/public/frontend/index.html ../crm_override/www/crm.html",
    "serve": "vite preview"
  },
  "dependencies": {
    "@tiptap/extension-paragraph": "^2.12.0",
    "@twilio/voice-sdk": "^2.10.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vueuse/integrations": "^10.3.0",
    "dompurify": "^3.3.3",
    "frappe-ui": "0.1.261",
    "gemoji": "^8.1.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "leaflet.locatecontrol": "^0.89.0",
    "lodash": "^4.18.1",
    "mime": "^4.0.1",
    "pinia": "^2.0.33",
    "socket.io-client": "^4.7.2",
    "sortablejs": "^1.15.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.21.2",
    "vue": "^3.5.13",
    "vue-router": "^4.2.2",
    "vuedraggable": "^4.1.0"
  },
  "resolutions": {
    "dompurify": "3.4.0",
    "brace-expansion": "2.1.0",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "fs-extra": "^11.2.0",
    "postcss": "^8.4.5",
    "tailwindcss": "^3.4.15"
  }
}
